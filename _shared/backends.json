{
  "schema_version": "1",
  "flavor": "antigravity",
  "multiagent_root_env": "MULTIAGENT_ROOT",
  "_note": "오케스트레이터 = Antigravity(agy/IDE, Gemini 3.1 Pro High). gemini 워커 없음 — 멀티모달/롱독은 오케스트레이터가 직접 수행(같은 벤더 worker는 독립성 무의미).",
  "workers": {
    "claude-main": {
      "model": "host-default",
      "call_type": "cli",
      "brief_mode": "content",
      "cli": {
        "command": "claude",
        "args_template": ["-p", "@brief_content"],
        "non_interactive": { "stdin": "/dev/null", "no_tty": true, "on_permission_prompt": "fail" }
      },
      "cwd_policy": "repo_root",
      "write_policy": "none",
      "approval_class": "worker",
      "result_capture": "envelope",
      "timeout": 600
    },
    "codex-main": {
      "model": "codex-default",
      "call_type": "cli",
      "brief_mode": "content",
      "cli": {
        "command": "codex",
        "args_template": ["exec", "@brief_content"],
        "non_interactive": { "stdin": "/dev/null", "no_tty": true, "on_permission_prompt": "fail" }
      },
      "cwd_policy": "repo_root",
      "write_policy": "none",
      "approval_class": "worker",
      "result_capture": "envelope",
      "timeout": 600
    },
    "codex-critic": {
      "model": "codex-default",
      "call_type": "cli",
      "brief_mode": "content",
      "cli": {
        "command": "codex",
        "args_template": ["exec", "@brief_content"],
        "non_interactive": { "stdin": "/dev/null", "no_tty": true, "on_permission_prompt": "fail" }
      },
      "cwd_policy": "repo_root",
      "write_policy": "none",
      "approval_class": "worker",
      "result_capture": "envelope",
      "timeout": 600
    }
  }
}
