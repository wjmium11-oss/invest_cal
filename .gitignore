# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Logs / temp
*.log
*.tmp

# 작업 데이터 — 사용자 사적 자료, git 추적 안 함 (폴더 구조 유지를 위해 .gitkeep만 추적)
tasks/*
!tasks/.gitkeep

# 프로젝트 특화 교훈 — 작성자 사적 누적물, git 추적 안 함 (폴더만 유지)
_local/*
!_local/.gitkeep

# Excel data sources (large binaries)
*.xlsx
*.xlxs

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
